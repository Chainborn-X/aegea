script = ExtResource("5_dialogue_interactable")
Speaker = "Tide Oracle"
Prompt = "Listen"
Lines = PackedStringArray("The road above the shrine is sealed by an old bronze key.", "Overgrowth hides small things from impatient hands.", "Cut the laurel bushes east of the stones. Listen for the chest.")

[node name="MyrineNpc" type="Area2D" parent="." unique_id=1069957956]
position = Vector2(720, 520)
script = ExtResource("5_dialogue_interactable")
Speaker = "Myrine"
Prompt = "Talk"
Lines = PackedStringArray("The shrine used to answer at dawn.", "Now the bushes grow fast and the little guardians bite at shadows.", "If you find the old key, do not force the northern gate. Let it wake.")

